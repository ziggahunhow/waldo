# LINE Messaging API — channel secret, always required (verifies webhook signatures)
LINE_CHANNEL_SECRET=

# LINE Messaging API — either set this long-lived access token directly...
LINE_CHANNEL_ACCESS_TOKEN=

# ...or leave it unset and provide both of these instead, to exchange a
# short-lived token automatically (see line_bot.py's _access_token()).
LINE_CHANNEL_ID=

# Your own LINE user ID. The bot only stays in groups/rooms you're a member
# of — DM the bot once and check logs/server.log for "on_text target=<id>".
ADMIN_LINE_USER_ID=

# Publicly reachable base URL of this server (e.g. https://abc123.ngrok.io).
# Required to send matched images back through LINE; without it the bot
# falls back to listing filenames only.
PUBLIC_URL=

# Optional. Without it, Drive folder downloads fall back to gdown (capped
# at ~50 files per folder). Get a free key at
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_API_KEY=
